.container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  padding: 40px;
}
.box {
  width: 100%;
  max-width: 400px;
  background: #fff;
  padding: 30px;
  border-radius: 10px;
  box-shadow: 0 0 10px rgba(0,0,0,0.1);
  text-align: center;
}
.title {
  display: block;
  font-size: 22px;
  font-weight: 600;
  margin-bottom: 20px;
}
.desc {
  font-size: 14px;
  color: #555;
  margin-bottom: 16px;
}
.input {
  width: 100%;
  padding: 12px;
  margin-bottom: 14px;
  border: 1px solid #ddd;
  border-radius: 5px;
  font-size: 16px;
}
.btn {
  width: 100%;
  padding: 12px;
  background: #409eff;
  color: #fff;
  border: none;
  border-radius: 5px;
  font-size: 16px;
  margin-top: 10px;
}
.link {
  display: block;
  color: #409eff;
  font-size: 14px;
  margin-top: 15px;
}