.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #fff;
  /* 入场动画 */
  animation: fadeIn 1s ease-out;
  /* 过渡动效，让淡出更平滑 */
  transition: opacity 0.6s ease-out;
}

/* 控制淡出 */
.container.fade-out {
  opacity: 0;
}

.logo {
  width: 160px;
  height: 160px;
  margin-bottom: 20px;
  animation: float 2s infinite ease-in-out;
}
.title {
  font-size: 30px;
  font-weight: 600;
  color: #222;
  margin-bottom: 8px;
}
.domain {
  color: #666;
  font-size: 16px;
  margin-bottom: 16px;
}
.desc {
  color: #999;
  font-size: 14px;
}

/* 关键帧动画 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}