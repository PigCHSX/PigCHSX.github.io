<view class="nav">
  <view class="nav-links">
    <navigator url="/pages/main/main">首页</navigator>
    <navigator url="/pages/read/read">阅读</navigator>
    <navigator url="/pages/login/login">投稿</navigator>
    <navigator url="/pages/messages/messages" class="active">留言</navigator>
  </view>
  <button class="logout-btn" bindtap="doLogout">退出登录</button>
</view>

<view class="container">
  <!-- 发表留言 -->
  <view class="message-form">
    <text class="form-title">💬 发表留言</text>
    <textarea class="form-textarea" placeholder="写下你想说的话..." value="{{content}}" bindinput="onContentInput"></textarea>
    <input class="form-input" placeholder="图片链接（可选，请先上传至图床）" value="{{picUrl}}" bindinput="onPicUrlInput" />
    <button class="form-btn" bindtap="postMessage">发布留言</button>
    <view class="form-tip">支持图片直链，推荐图床：路过图床、SM.MS</view>
  </view>

  <!-- 留言列表 -->
  <view class="message-list">
    <text class="list-title">📝 留言列表</text>
    <block wx:if="{{loading}}">
      <view class="loading">加载中...</view>
    </block>
    <block wx:elif="{{messages.length === 0}}">
      <view class="empty">暂无留言，快来抢沙发吧！</view>
    </block>
    <block wx:else>
      <view class="message-item" wx:for="{{messages}}" wx:key="id">
        <view class="message-header">
          <text class="message-user">{{item.username || '匿名'}}</text>
          <text class="message-time">{{item.time}}</text>
        </view>
        <view class="message-content">{{item.content}}</view>
        <image wx:if="{{item.pic_url}}" src="{{item.pic_url}}" class="message-pic" mode="widthFix" binderror="onImageError"></image>
      </view>
    </block>
  </view>
</view>

